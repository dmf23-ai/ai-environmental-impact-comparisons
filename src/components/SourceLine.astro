---
interface Source {
  name: string;
  url: string;
}
interface Props {
  sources: Source[];
  lastVerified: string;
}
const { sources, lastVerified } = Astro.props;
---

<footer class="source-line">
  <p class="sources">
    <span class="prefix">Sources:</span>
    {
      sources.map((s, i) => (
        <>
          <a href={s.url} target="_blank" rel="noopener noreferrer">
            {s.name}
          </a>
          {i < sources.length - 1 ? "; " : "."}
        </>
      ))
    }
  </p>
  <p class="verified">Last verified: <time datetime={lastVerified}>{lastVerified}</time></p>
</footer>

<style>
  .source-line {
    border-top: 1px solid var(--rule);
    padding-top: 0.85rem;
    margin-top: 1.75rem;
    font-size: 0.85rem;
    color: var(--ink-soft);
  }
  .sources,
  .verified {
    margin: 0 0 0.3rem;
    line-height: 1.5;
  }
  .prefix {
    font-weight: 500;
  }
  .source-line a {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: rgba(0, 0, 0, 0.25);
    text-underline-offset: 2px;
  }
  .source-line a:hover {
    color: var(--accent);
    text-decoration-color: currentColor;
  }
</style>
