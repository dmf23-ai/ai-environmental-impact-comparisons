---
interface Source {
  name: string;
  url: string;
}
interface Props {
  sources: Source[];
  lastVerified: string;
  methodsAnchor?: string;
  /**
   * Optional short attribution text shown in place of the long linked
   * source list. When provided, only this compact line is rendered
   * (e.g. "Sources: IEA, LBNL, EIA, Cambridge CCAF.") plus the verified
   * stamp and the "how this was calculated" link. The full clickable
   * source names live on /methods for now (eventually the link will open
   * an in-page popup).
   */
  shortText?: string;
}
const { sources, lastVerified, methodsAnchor, shortText } = Astro.props;
---

<footer class="source-line">
  {shortText ? (
    <p class="sources">{shortText}</p>
  ) : (
    <p class="sources">
      <span class="prefix">Sources:</span>
      {sources.map((s, i) => (
        <>
          <a href={s.url} target="_blank" rel="noopener noreferrer">
            {s.name}
          </a>
          {i < sources.length - 1 ? "; " : "."}
        </>
      ))}
    </p>
  )}
  <p class="verified">Last verified: <time datetime={lastVerified}>{lastVerified}</time></p>
  {methodsAnchor && (
    <p class="methods-link">
      <a href={`/methods#${methodsAnchor}`}>How this was calculated →</a>
    </p>
  )}
</footer>

<style>
  .source-line {
    border-top: 1px solid var(--rule);
    padding-top: 0.7rem;
    margin-top: 1.4rem;
    font-size: 0.78rem;
    color: var(--ink-soft);
  }
  .sources,
  .verified,
  .methods-link {
    margin: 0 0 0.25rem;
    line-height: 1.5;
  }
  .prefix {
    font-weight: 500;
  }
  .source-line a {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: rgba(0, 0, 0, 0.25);
    text-underline-offset: 2px;
  }
  .source-line a:hover {
    color: var(--accent);
    text-decoration-color: currentColor;
  }
  .methods-link {
    margin-top: 0.45rem;
  }
</style>
