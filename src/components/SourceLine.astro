---
import OrnatePopupTrigger from "./OrnatePopupTrigger.astro";

interface Source {
  name: string;
  url: string;
  /** Short label rendered in the compact source line (e.g. "IEA", "LBNL"). */
  abbrev?: string;
}
interface Props {
  sources: Source[];
  lastVerified: string;
  methodsAnchor?: string;
  /**
   * When set, the "How this was calculated →" link opens the named
   * OrnatePopup template in-page instead of navigating to /methods. The
   * /methods anchor is still rendered as a fallback link inside the popup
   * for the deep-dive prose. Provide the existing per-chart popup id
   * (e.g. "year-ai", "water-counting", "training-inference").
   */
  methodsPopupId?: string;
  /**
   * When true, render the compact one-line attribution: every source as
   * its `abbrev` (or first word of its `name`), wrapped in a link to the
   * source URL.
   */
  compact?: boolean;
}
const { sources, lastVerified, methodsAnchor, methodsPopupId, compact = false } = Astro.props;

function shortLabel(s: Source): string {
  if (s.abbrev) return s.abbrev;
  const dashIdx = s.name.indexOf(" — ");
  if (dashIdx > 0) return s.name.slice(0, dashIdx);
  return s.name.split(",")[0].split(":")[0];
}
---

<footer class="source-line">
  {compact ? (
    <p class="sources">
      <span class="prefix">Sources:</span>{" "}
      {sources.map((s, i) => (
        <>
          <a href={s.url} target="_blank" rel="noopener noreferrer">
            {shortLabel(s)}
          </a>
          {i < sources.length - 1 ? ", " : "."}
        </>
      ))}
    </p>
  ) : (
    <p class="sources">
      <span class="prefix">Sources:</span>{" "}
      {sources.map((s, i) => (
        <>
          <a href={s.url} target="_blank" rel="noopener noreferrer">
            {s.name}
          </a>
          {i < sources.length - 1 ? "; " : "."}
        </>
      ))}
    </p>
  )}
  <p class="verified">Last verified: <time datetime={lastVerified}>{lastVerified}</time></p>
  {methodsPopupId ? (
    <div class="methods-link">
      <OrnatePopupTrigger popupId={methodsPopupId} as="prose" label="How this was calculated">
        How this was calculated →
      </OrnatePopupTrigger>
    </div>
  ) : methodsAnchor ? (
    <div class="methods-link">
      <a href={`/methods#${methodsAnchor}`}>How this was calculated →</a>
    </div>
  ) : null}
</footer>

<style>
  .source-line {
    border-top: 1px solid var(--rule);
    padding-top: 0.7rem;
    margin-top: 1.4rem;
    font-size: 0.78rem;
    color: var(--ink-soft);
  }
  .sources,
  .verified,
  .methods-link {
    margin: 0 0 0.25rem;
    line-height: 1.5;
  }
  .prefix {
    font-weight: 500;
  }
  .source-line a {
    color: var(--ink-soft);
    text-decoration: underline;
    text-decoration-color: rgba(0, 0, 0, 0.25);
    text-underline-offset: 2px;
  }
  .source-line a:hover {
    color: var(--accent);
    text-decoration-color: currentColor;
  }
  .methods-link {
    margin-top: 0.45rem;
  }
  /* The popup trigger inside the methods-link line should read as plain
     text with our soft underline, matching the other source-line links. */
  .methods-link :global(.ornate-popup-trigger-prose) {
    color: var(--ink-soft);
    border-bottom: 1px solid rgba(0, 0, 0, 0.25);
  }
  .methods-link :global(.ornate-popup-trigger-prose:hover) {
    color: var(--accent);
    border-bottom-color: currentColor;
  }
</style>
