---
// OrganicFrame — thin warm-ink border with asymmetric rounded corners and a
// paper background. The standard card chrome in the Mucha's Notebook
// redesign; replaces the prior rectangular bordered card. Phase 2 will add
// small SVG flourishes at the rounded corners; for now the asymmetric
// rounding alone provides the organic gesture.
---

<div class="organic-frame">
  <slot />
</div>

<style>
  .organic-frame {
    position: relative;
    border: 1px solid var(--ink-soft);
    background: var(--paper);
    border-radius: 0 18px 0 18px;
    padding: var(--space-6) var(--space-5);
    margin: var(--space-6) 0 var(--space-7);
  }
  @media (min-width: 720px) {
    .organic-frame {
      padding: var(--space-7) var(--space-7);
      border-radius: 0 24px 0 24px;
    }
  }
</style>
