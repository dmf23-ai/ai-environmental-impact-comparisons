---
// OrganicFrame — thin warm-ink border with asymmetric rounded corners and a
// paper background. A small fiddlehead-style CornerCurl sits at the top-right
// corner; the bottom-left is asymmetrically rounded to echo. Standard card
// chrome for the Mucha's Notebook redesign.
import CornerCurl from "./CornerCurl.astro";
---

<div class="organic-frame">
  <slot />
  <CornerCurl corner="tr" />
</div>

<style>
  .organic-frame {
    position: relative;
    border: 1px solid var(--ink-soft);
    background: var(--paper);
    border-radius: 0 18px 0 18px;
    padding: var(--space-6) var(--space-5);
    margin: var(--space-6) 0 var(--space-7);
  }
  @media (min-width: 720px) {
    .organic-frame {
      padding: var(--space-7) var(--space-7);
      border-radius: 0 24px 0 24px;
    }
  }
</style>
