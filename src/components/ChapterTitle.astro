---
// ChapterTitle — chapter-opening header for the home page.
// Sits between the chapter's SectionDivider and the intro paragraph.
//
// Layout (centered, top to bottom):
//   - Small-caps "Chapter N" kicker (Cardo, ink-soft, Roman numeral)
//   - Large Cardo display title (no dropcap)
//   - Thin ornament rule (a plain horizontal hairline — no diamond)
//   - Sage-italic headline sentence (optional)
//
// Phase 3.5 refactor: kicker switched from Inter to Cardo so the chapter
// signage matches the editorial annotation columns inside each plate; the
// terracotta dropcap retired (it competed with the ornate cartouche for
// first-look attention); the diamond on the chapter rule retired (it
// duplicated the SectionDivider's carbon-chapter diamond and read as a
// stray glyph on the others).

interface Props {
  number: 1 | 2 | 3 | 4 | 5 | 6;
  title: string;
  headline?: string;
}
const { number, title, headline } = Astro.props;

const romanNumerals: Record<number, string> = {
  1: "I",
  2: "II",
  3: "III",
  4: "IV",
  5: "V",
  6: "VI",
};
const roman = romanNumerals[number];
---

<header class="chapter-title">
  <p class="chapter-kicker">Chapter {roman}</p>
  <h2 class="chapter-heading">{title}</h2>
  <hr class="chapter-rule" aria-hidden="true" />
  {headline && <p class="chapter-headline">{headline}</p>}
</header>

<style>
  .chapter-title {
    text-align: center;
    margin: var(--space-6) 0 var(--space-7);
  }
  .chapter-kicker {
    font-family: var(--font-serif);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.26em;
    color: var(--ink-soft);
    margin: 0 0 var(--space-3);
  }
  .chapter-heading {
    font-family: var(--font-serif);
    font-weight: 700;
    font-size: 2.4rem;
    line-height: 1.1;
    color: var(--ink);
    margin: 0 auto;
    letter-spacing: -0.005em;
    max-width: 36rem;
  }
  .chapter-rule {
    width: 5rem;
    height: 1px;
    border: none;
    background: var(--ink-soft);
    margin: var(--space-4) auto;
  }
  .chapter-headline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.2rem;
    line-height: 1.5;
    color: var(--subject-electricity);
    margin: 0 auto;
    max-width: 30rem;
  }
  @media (min-width: 720px) {
    .chapter-kicker {
      font-size: 0.88rem;
    }
    .chapter-heading {
      font-size: 3.2rem;
    }
    .chapter-headline {
      font-size: 1.4rem;
    }
    .chapter-rule {
      width: 7rem;
    }
  }
</style>
