---
interface Figure {
  label: string;
  value?: number;
  value_low?: number;
  value_high?: number;
  confidence?: string;
}
interface Props {
  figures: Figure[];
  max?: number;
}
const { figures } = Astro.props;

// Compute the chart's right-edge value: the largest high (or value) across all
// figures, rounded up to a clean number for a tidy axis.
function niceCeiling(n: number): number {
  if (n <= 10) return Math.ceil(n);
  const magnitude = Math.pow(10, Math.floor(Math.log10(n)));
  const mantissa = n / magnitude;
  let rounded;
  if (mantissa <= 1) rounded = 1;
  else if (mantissa <= 2) rounded = 2;
  else if (mantissa <= 2.5) rounded = 2.5;
  else if (mantissa <= 5) rounded = 5;
  else rounded = 10;
  return rounded * magnitude;
}

const rawMax = Math.max(
  ...figures.map((f) => f.value_high ?? f.value ?? 0)
);
const maxVal = Astro.props.max ?? niceCeiling(rawMax);

const fmt = (n: number) => n.toLocaleString("en-US");

function formatRange(f: Figure): { label: string; low: number; high: number } {
  if (f.value !== undefined) {
    return { label: fmt(f.value), low: f.value, high: f.value };
  }
  const lo = f.value_low ?? 0;
  const hi = f.value_high ?? 0;
  return { label: `${fmt(lo)}–${fmt(hi)}`, low: lo, high: hi };
}
---

<div class="range-bars" role="img" aria-label="Comparison bars">
  {
    figures.map((f) => {
      const r = formatRange(f);
      const isPoint = r.low === r.high;
      const fillPct = (r.high / maxVal) * 100;
      const leftPct = (r.low / maxVal) * 100;
      const widthPct = ((r.high - r.low) / maxVal) * 100;
      return (
        <div class="bar-row">
          <div class="bar-header">
            <span class="bar-label">{f.label}</span>
            <span class="bar-value">{r.label}</span>
          </div>
          <div class="bar-track">
            {isPoint ? (
              <div class="bar-fill" style={`width: ${fillPct}%`} />
            ) : (
              <div
                class="bar-band"
                style={`left: ${leftPct}%; width: ${widthPct}%`}
              />
            )}
          </div>
        </div>
      );
    })
  }
  <div class="axis">
    <span>0</span>
    <span>{fmt(maxVal)}</span>
  </div>
</div>

<style>
  .range-bars {
    display: grid;
    gap: 1.1rem;
    margin: 1.5rem 0 0.5rem;
  }
  .bar-row {
    display: grid;
    gap: 0.35rem;
  }
  .bar-header {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: baseline;
    font-size: 0.92rem;
  }
  .bar-label {
    color: var(--ink);
  }
  .bar-value {
    color: var(--ink);
    font-variant-numeric: tabular-nums;
    font-weight: 500;
    white-space: nowrap;
  }
  .bar-track {
    position: relative;
    height: 16px;
    background: rgba(0, 0, 0, 0.05);
    border-radius: 3px;
    overflow: hidden;
  }
  .bar-fill {
    height: 100%;
    background: var(--accent);
    border-radius: 3px;
  }
  .bar-band {
    position: absolute;
    top: 0;
    height: 100%;
    background: var(--accent);
    opacity: 0.85;
    border-radius: 3px;
    /* a soft stripe to suggest "range, not point" */
    background-image: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.18) 25%,
      transparent 25%,
      transparent 50%,
      rgba(255, 255, 255, 0.18) 50%,
      rgba(255, 255, 255, 0.18) 75%,
      transparent 75%,
      transparent
    );
    background-size: 8px 8px;
  }
  .axis {
    display: flex;
    justify-content: space-between;
    font-size: 0.78rem;
    color: var(--ink-soft);
    font-variant-numeric: tabular-nums;
    margin-top: 0.4rem;
    padding-top: 0.4rem;
    border-top: 1px solid var(--rule);
  }
</style>
