---
// SubjectMarker — small filled motif in the top-right corner of an
// OrganicFrame. Tells the reader the card's subject (water / electricity /
// carbon) at a glance, using the same motif vocabulary as the section
// dividers so the visual language reads as one system.
//
// Replaces the prior CornerCurl: that was decoration without information.
// This earns its place by communicating.
//
// Props:
//   subject: "water" | "electricity" | "carbon"
//   size:    number   — pixel size of the SVG. Default 30.

interface Props {
  subject: "water" | "electricity" | "carbon";
  size?: number;
}
const { subject, size = 30 } = Astro.props;

const subjectColors: Record<string, string> = {
  water: "var(--subject-water)",
  electricity: "var(--subject-electricity)",
  carbon: "var(--subject-carbon)",
};
const color = subjectColors[subject];
---

<svg
  class="subject-marker"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  style={`color: ${color}`}
  aria-hidden="true"
>
  {subject === "water" && (
    <path
      d="M 12 4 C 9 9, 5 13, 5 15 A 7 7 0 0 0 19 15 C 19 13, 15 9, 12 4 Z"
      fill="currentColor"
    />
  )}
  {subject === "electricity" && (
    <path
      d="M 14 2 L 5 13 L 11 13 L 8 22 L 19 11 L 13 11 L 16 2 Z"
      fill="currentColor"
    />
  )}
  {subject === "carbon" && (
    <path
      d="M 12 4 L 20 12 L 12 20 L 4 12 Z"
      fill="currentColor"
    />
  )}
</svg>

<style>
  .subject-marker {
    position: absolute;
    top: 10px;
    right: 12px;
    pointer-events: none;
    display: block;
  }
</style>
