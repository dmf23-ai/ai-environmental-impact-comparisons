---
// NumericCartouche — ornamental container for a chart's headline figure.
// Display-size Cardo number flanked by two small subject-colored almond
// flourishes, with optional unit and caption. Used at the top of bar charts
// to surface the most consequential figure before the chart itself is read.
//
// Ornate variant (Phase 2e.1): pass `ornate={true}` to wrap the value in an
// Art Nouveau cartouche frame asset (/ornaments/cartouche-frame.png). The
// ornate variant locks to the asset's native 3:2 aspect so the frame's
// embellishments don't stretch. Value and unit stack vertically inside so
// long unit phrases (e.g., "billion gallons") don't blow out the box.
//
// Run-6 (2026-05-29): ornate value/unit sizing switched to container queries
// so values like "14–18" or "830–1,350" don't wrap when the cartouche sits
// in a narrow plate-annotation column. White-space: nowrap is the load-bearing
// fix — wrapping was forcing the figure past the frame's 3:2 box and over the
// bottom border ornament.

interface Props {
  value: string;
  unit?: string;
  caption?: string;
  subject: "water" | "electricity" | "carbon";
  ornate?: boolean;
}
const { value, unit, caption, subject, ornate = false } = Astro.props;

const subjectColors: Record<string, string> = {
  water: "var(--subject-water)",
  electricity: "var(--subject-electricity)",
  carbon: "var(--subject-carbon)",
};
const color = subjectColors[subject];
---

<div class:list={["cartouche-wrap", ornate && "cartouche-wrap-ornate"]}>
  <div class:list={["cartouche", ornate && "cartouche-ornate"]}>
    {ornate && (
      <img
        class="cartouche-frame-bg"
        src="/ornaments/cartouche-frame.png"
        alt=""
        aria-hidden="true"
      />
    )}
    <span class="flourish" style={`color: ${color}`} aria-hidden="true">
      <svg viewBox="0 0 8 16" width="8" height="16">
        <path
          d="M 4 2 C 6.5 5, 6.5 11, 4 14 C 1.5 11, 1.5 5, 4 2 Z"
          fill="currentColor"
        />
      </svg>
    </span>
    <span class="figure">
      <span class="value">{value}</span>
      {unit && <span class="unit">{unit}</span>}
    </span>
    <span class="flourish" style={`color: ${color}`} aria-hidden="true">
      <svg viewBox="0 0 8 16" width="8" height="16">
        <path
          d="M 4 2 C 6.5 5, 6.5 11, 4 14 C 1.5 11, 1.5 5, 4 2 Z"
          fill="currentColor"
        />
      </svg>
    </span>
  </div>
  {caption && <p class="cartouche-caption">{caption}</p>}
</div>

<style>
  .cartouche-wrap {
    margin: 0 0 var(--space-5);
  }
  .cartouche-wrap-ornate {
    text-align: center;
  }
  .cartouche {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: var(--space-3);
    margin: 0;
  }
  /* Ornate variant locks to the asset's 3:2 aspect so the frame doesn't
     stretch. Long unit phrases stack below the value rather than running
     out horizontally. container-type: inline-size lets the value/unit
     font-size scale with the cartouche's actual rendered width via cqi. */
  .cartouche-ornate {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    width: 100%;
    max-width: 360px;
    aspect-ratio: 3 / 2;
    margin: 0 auto;
    padding: 0;
    container-type: inline-size;
    container-name: cartouche;
  }
  .cartouche-frame-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: fill;
    pointer-events: none;
    user-select: none;
    z-index: 0;
  }
  .cartouche-ornate > .flourish,
  .cartouche-ornate > .figure {
    position: relative;
    z-index: 1;
  }
  /* In ornate mode, stack value over unit vertically so long unit phrases
     stay readable inside the 3:2 box. */
  .cartouche-ornate > .figure {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.1em;
    /* Keep the figure inside the frame's interior horizontally. The frame
       asset's safe inner band is roughly 80% of its width. */
    max-width: 80%;
  }
  .flourish {
    display: inline-flex;
    align-self: center;
    line-height: 0;
  }
  .flourish svg {
    display: block;
  }
  .figure {
    display: inline-flex;
    align-items: baseline;
    gap: 0.3em;
    font-family: var(--font-serif);
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.005em;
  }
  .value {
    font-size: 2.5rem;
    line-height: 1.1;
  }
  .unit {
    font-size: 1.1rem;
    font-weight: 400;
    font-style: italic;
    color: var(--ink-soft);
    letter-spacing: 0;
  }
  /* Ornate value/unit autoshrink with the cartouche's container width.
     nowrap prevents the en-dash wrap that used to push "14–18" and
     "830–1,350" past the frame's bottom ornament. Caps at the previous
     desktop maxes (2.4rem value, 1.05rem unit) so the visual rhythm at
     full-size cartouches is unchanged. */
  .cartouche-ornate .value {
    font-size: clamp(0.85rem, 16cqi, 2.6rem);
    line-height: 1.05;
    white-space: nowrap;
  }
  .cartouche-ornate .unit {
    font-size: clamp(0.65rem, 6cqi, 1.2rem);
    white-space: nowrap;
  }
  .cartouche-caption {
    text-align: center;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.02rem;
    color: var(--ink-soft);
    line-height: 1.4;
    margin: var(--space-2) 0 0;
  }
  @media (min-width: 720px) {
    .value {
      font-size: 3rem;
    }
    .unit {
      font-size: 1.25rem;
    }
    .cartouche-ornate {
      max-width: 400px;
    }
  }
</style>
