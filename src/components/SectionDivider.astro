---
// SectionDivider — chapter-opening illustrated horizontal divider.
// Layout: thin rule on the left, motif in the center, thin rule on the right.
// Strokes thickened and small filled accents added so the subject colors
// (sage, teal, rust) hold their saturation against the ivory paper.

interface Props {
  motif: "wheat" | "vine" | "water" | "carbon";
  color?: string;
}
const { motif, color } = Astro.props;

const subjectColors: Record<string, string> = {
  wheat: "var(--subject-electricity)",
  vine: "var(--subject-electricity)",
  water: "var(--subject-water)",
  carbon: "var(--subject-carbon)",
};
const resolvedColor = color ?? subjectColors[motif];
---

<div class="section-divider">
  <span class="rule"></span>
  <span class="motif" style={`color: ${resolvedColor}`} aria-hidden="true">
    {motif === "wheat" && (
      <svg viewBox="0 0 56 40" width="56" height="40">
        <line
          x1="28"
          y1="6"
          x2="28"
          y2="34"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
        <ellipse cx="22" cy="11" rx="3.4" ry="1.6" fill="currentColor" transform="rotate(-30 22 11)" />
        <ellipse cx="34" cy="11" rx="3.4" ry="1.6" fill="currentColor" transform="rotate(30 34 11)" />
        <ellipse cx="21" cy="20" rx="3.6" ry="1.6" fill="currentColor" transform="rotate(-30 21 20)" />
        <ellipse cx="35" cy="20" rx="3.6" ry="1.6" fill="currentColor" transform="rotate(30 35 20)" />
        <ellipse cx="22" cy="29" rx="3.4" ry="1.6" fill="currentColor" transform="rotate(-30 22 29)" />
        <ellipse cx="34" cy="29" rx="3.4" ry="1.6" fill="currentColor" transform="rotate(30 34 29)" />
      </svg>
    )}
    {motif === "vine" && (
      <svg viewBox="0 0 70 30" width="70" height="30">
        <path
          d="M 0 15 C 18 15, 18 8, 35 15 C 52 22, 52 15, 70 15"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        />
        <path
          d="M 22 11 C 26 5, 32 7, 28 13 C 25 11, 22 11, 22 11 Z"
          fill="currentColor"
        />
        <path
          d="M 48 19 C 44 25, 38 23, 42 17 C 45 19, 48 19, 48 19 Z"
          fill="currentColor"
        />
      </svg>
    )}
    {motif === "water" && (
      <svg viewBox="0 0 70 30" width="70" height="30">
        <path
          d="M 18 4 C 22 8, 22 14, 18 14 C 14 14, 14 8, 18 4 Z"
          fill="currentColor"
        />
        <path
          d="M 52 4 C 56 8, 56 14, 52 14 C 48 14, 48 8, 52 4 Z"
          fill="currentColor"
        />
        <path
          d="M 0 22 C 12 16, 23 28, 35 22 C 47 16, 58 28, 70 22"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
        />
      </svg>
    )}
    {motif === "carbon" && (
      <svg viewBox="0 0 24 24" width="24" height="24">
        <path d="M 12 4 L 20 12 L 12 20 L 4 12 Z" fill="currentColor" />
      </svg>
    )}
  </span>
  <span class="rule"></span>
</div>

<style>
  .section-divider {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin: var(--space-7) 0 var(--space-5);
  }
  .rule {
    flex: 1;
    height: 1px;
    background: var(--rule);
  }
  .motif {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }
  .motif svg {
    display: block;
  }
</style>
