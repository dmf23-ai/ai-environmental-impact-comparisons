---
// SectionDivider — chapter-opening illustrated horizontal divider.
// Layout: thin rule on the left, motif in the center, thin rule on the right.
// The motif communicates the chapter's subject; the subject color auto-applies
// unless overridden via the `color` prop.
//
// Motifs:
//   "wheat"  — vertical wheat-stalk with grain marks (electricity / energy)
//   "vine"   — horizontal vine with two leaves (trajectory / growth)
//   "water"  — wave (water)
//   "carbon" — filled ink diamond (carbon — most restrained of the four)

interface Props {
  motif: "wheat" | "vine" | "water" | "carbon";
  color?: string;
}
const { motif, color } = Astro.props;

const subjectColors: Record<string, string> = {
  wheat: "var(--subject-electricity)",
  vine: "var(--subject-electricity)",
  water: "var(--subject-water)",
  carbon: "var(--subject-carbon)",
};
const resolvedColor = color ?? subjectColors[motif];
---

<div class="section-divider">
  <span class="rule"></span>
  <span class="motif" style={`color: ${resolvedColor}`} aria-hidden="true">
    {motif === "wheat" && (
      <svg viewBox="0 0 50 40" width="50" height="40">
        <line
          x1="25"
          y1="6"
          x2="25"
          y2="34"
          stroke="currentColor"
          stroke-width="1.3"
          stroke-linecap="round"
        />
        <path
          d="M 25 12 L 17 9 M 25 12 L 33 9 M 25 20 L 16 16 M 25 20 L 34 16 M 25 28 L 17 24 M 25 28 L 33 24"
          stroke="currentColor"
          stroke-width="1.2"
          fill="none"
          stroke-linecap="round"
        />
      </svg>
    )}
    {motif === "vine" && (
      <svg viewBox="0 0 70 30" width="70" height="30">
        <path
          d="M 0 15 C 18 15, 18 8, 35 15 C 52 22, 52 15, 70 15"
          fill="none"
          stroke="currentColor"
          stroke-width="1.3"
          stroke-linecap="round"
        />
        <path
          d="M 22 11 C 26 5, 32 7, 28 13 C 25 11, 22 11, 22 11 Z"
          fill="none"
          stroke="currentColor"
          stroke-width="1.1"
          stroke-linejoin="round"
        />
        <path
          d="M 48 19 C 44 25, 38 23, 42 17 C 45 19, 48 19, 48 19 Z"
          fill="none"
          stroke="currentColor"
          stroke-width="1.1"
          stroke-linejoin="round"
        />
      </svg>
    )}
    {motif === "water" && (
      <svg viewBox="0 0 70 20" width="70" height="20">
        <path
          d="M 0 10 C 12 0, 23 20, 35 10 C 47 0, 58 20, 70 10"
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
          stroke-linecap="round"
        />
      </svg>
    )}
    {motif === "carbon" && (
      <svg viewBox="0 0 20 20" width="20" height="20">
        <path d="M 10 4 L 16 10 L 10 16 L 4 10 Z" fill="currentColor" />
      </svg>
    )}
  </span>
  <span class="rule"></span>
</div>

<style>
  .section-divider {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin: var(--space-7) 0 var(--space-5);
  }
  .rule {
    flex: 1;
    height: 1px;
    background: var(--rule);
  }
  .motif {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }
  .motif svg {
    display: block;
  }
</style>
