---
import RangeBar from "./RangeBar.astro";
import SourceLine from "./SourceLine.astro";

interface Source {
  name: string;
  url: string;
}
interface Figure {
  label: string;
  value?: number;
  value_low?: number;
  value_high?: number;
  confidence?: string;
}
interface Props {
  id: string;
  anchor: string;
  title: string;
  summary: string;
  unit_caption?: string;
  figures: Figure[];
  sources: Source[];
  last_verified: string;
}
const {
  anchor,
  title,
  summary,
  unit_caption,
  figures,
  sources,
  last_verified,
} = Astro.props;
---

<article class="comparison-card" id={anchor}>
  <h2 class="comparison-title">
    <a href={`#${anchor}`} class="anchor-link" aria-label="Link to this comparison"
      >{title}</a
    >
  </h2>
  <p class="comparison-summary">{summary}</p>
  {unit_caption && <p class="unit-caption">{unit_caption}</p>}
  <RangeBar figures={figures} />
  <SourceLine sources={sources} lastVerified={last_verified} />
</article>

<style>
  .comparison-card {
    background: white;
    border: 1px solid var(--rule);
    border-radius: 6px;
    padding: 2rem 1.5rem;
    margin: 2rem 0;
  }
  .comparison-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 1rem;
    line-height: 1.3;
    letter-spacing: -0.005em;
  }
  .anchor-link {
    color: inherit;
    text-decoration: none;
  }
  .anchor-link:hover {
    color: var(--accent);
  }
  .comparison-summary {
    margin: 0;
    color: var(--ink);
    font-size: 1rem;
    line-height: 1.6;
  }
  .unit-caption {
    font-size: 0.72rem;
    color: var(--ink-soft);
    margin: 1.6rem 0 -0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  @media (min-width: 720px) {
    .comparison-card {
      padding: 2.25rem 2.25rem;
    }
    .comparison-title {
      font-size: 1.4rem;
    }
    .comparison-summary {
      font-size: 1.05rem;
    }
  }
</style>
