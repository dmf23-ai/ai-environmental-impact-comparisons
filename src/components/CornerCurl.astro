---
// CornerCurl — small SVG flourish for the corners of OrganicFrame.
// A single continuous line: sweeping arc that resolves into a small terminal
// curl. Restrained Nouveau — feels organic without tipping into ornament-heavy
// Tiffany-lamp territory.
//
// Props:
//   corner: "tr" | "bl"  — which corner this sits at. Default "tr".
//                          "bl" rotates the path 180° so the curl mirrors.
//   size:   number       — pixel size of the SVG. Default 40.
//   color:  string       — CSS color value. Default uses --ink-soft.

interface Props {
  corner?: "tr" | "bl";
  size?: number;
  color?: string;
}
const {
  corner = "tr",
  size = 40,
  color = "var(--ink-soft)",
} = Astro.props;

const rotation = corner === "bl" ? 180 : 0;
---

<svg
  class:list={["corner-curl", `corner-${corner}`]}
  width={size}
  height={size}
  viewBox="0 0 40 40"
  style={`color: ${color}`}
  aria-hidden="true"
>
  <g transform={`rotate(${rotation} 20 20)`}>
    <path
      d="M 30 10 C 30 26, 10 26, 10 16 C 10 8, 22 8, 20 16 C 18 22, 24 22, 24 16"
      fill="none"
      stroke="currentColor"
      stroke-width="1.3"
      stroke-linecap="round"
      stroke-linejoin="round"
    />
  </g>
</svg>

<style>
  .corner-curl {
    position: absolute;
    pointer-events: none;
    display: block;
  }
  .corner-curl.corner-tr {
    top: 6px;
    right: 6px;
  }
  .corner-curl.corner-bl {
    bottom: 6px;
    left: 6px;
  }
</style>
