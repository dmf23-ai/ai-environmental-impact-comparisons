---
import RangeBar from "./RangeBar.astro";
import SourceLine from "./SourceLine.astro";
import figuresData from "../data/figures.json";

const data = figuresData.hourly_impact;
const allFigures = data.figures;
// "Small" = anything well below the driving bar's range, so the zoom chart can
// show the digital activities legibly.
const smallFigures = allFigures.filter(
  (f: { value_high?: number; value?: number }) =>
    (f.value_high ?? f.value ?? 0) < 1000
);
---

<figure class="hourly-hero">
  <header>
    <p class="kicker">{data.kicker}</p>
    <h2 class="hero-title">{data.title}</h2>
  </header>

  <div class="chart-block">
    <p class="unit-caption">Grams of CO₂ equivalent per hour</p>
    <RangeBar figures={allFigures} />
  </div>

  <div class="chart-block">
    <p class="unit-caption">
      Same activities, driving omitted so the others are readable
    </p>
    <RangeBar figures={smallFigures} />
  </div>

  <figcaption>{data.summary}</figcaption>

  <SourceLine sources={data.sources} lastVerified={data.last_verified} />
</figure>

<style>
  .hourly-hero {
    background: white;
    border: 1px solid var(--rule);
    border-radius: 8px;
    padding: var(--space-6) var(--space-5);
    margin: var(--space-6) 0 var(--space-7);
    box-shadow:
      0 1px 0 rgba(31, 41, 55, 0.02),
      0 6px 18px -8px rgba(31, 41, 55, 0.1);
  }
  .kicker {
    font-size: 0.72rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 var(--space-2);
  }
  .hero-title {
    font-family: var(--font-serif);
    font-size: 1.4rem;
    line-height: 1.25;
    letter-spacing: -0.005em;
    margin: 0;
  }
  .chart-block {
    margin-top: var(--space-6);
  }
  .unit-caption {
    font-size: 0.72rem;
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
  }
  figcaption {
    font-size: 1rem;
    color: var(--ink);
    margin: var(--space-6) 0 0;
    line-height: 1.6;
    border-top: 1px solid var(--rule);
    padding-top: var(--space-5);
  }
  @media (min-width: 720px) {
    .hourly-hero {
      padding: var(--space-7) var(--space-7);
    }
    .hero-title {
      font-size: 1.7rem;
    }
  }
</style>
