---
import OrganicFrame from "./OrganicFrame.astro";
import RangeBar from "./RangeBar.astro";
import SourceLine from "./SourceLine.astro";
import figuresData from "../data/figures.json";

const data = figuresData.hourly_impact;
const allFigures = data.figures;
// "Small" = anything well below the driving bar's range, so the zoom chart can
// show the digital activities legibly.
const smallFigures = allFigures.filter(
  (f: { value_high?: number; value?: number }) =>
    (f.value_high ?? f.value ?? 0) < 1000
);
const headlineSentence =
  "An hour of driving emits roughly a thousand times the CO₂ of an hour of AI chat.";
---

<OrganicFrame>
  <figure class="hourly-hero">
    <header>
      <p class="kicker">{data.kicker}</p>
      <h2 class="hero-title">{data.title}</h2>
      <p class="at-a-glance">{headlineSentence}</p>
    </header>

    <div class="chart-block">
      <p class="unit-caption">Grams of CO₂ equivalent per hour</p>
      <RangeBar figures={allFigures} />
    </div>

    <div class="chart-block">
      <p class="unit-caption">
        Same activities, driving omitted so the others are readable
      </p>
      <RangeBar figures={smallFigures} />
    </div>

    <figcaption>{data.summary}</figcaption>

    <SourceLine
      sources={data.sources}
      lastVerified={data.last_verified}
      methodsAnchor="hourly-hero"
    />
  </figure>
</OrganicFrame>

<style>
  .hourly-hero {
    margin: 0;
  }
  .kicker {
    font-size: 0.75rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    margin: 0 0 var(--space-2);
  }
  .hero-title {
    font-family: var(--font-serif);
    font-size: 1.55rem;
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.005em;
    margin: 0;
  }
  .at-a-glance {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--subject-electricity);
    line-height: 1.45;
    margin: var(--space-3) 0 0;
  }
  .chart-block {
    margin-top: var(--space-6);
  }
  .unit-caption {
    font-size: 0.78rem;
    color: var(--ink-soft);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
  }
  figcaption {
    font-size: 1rem;
    color: var(--ink);
    margin: var(--space-6) 0 0;
    line-height: 1.65;
    border-top: 1px solid var(--rule);
    padding-top: var(--space-5);
  }
  @media (min-width: 720px) {
    .hero-title {
      font-size: 1.95rem;
    }
    .at-a-glance {
      font-size: 1.2rem;
    }
  }
</style>
