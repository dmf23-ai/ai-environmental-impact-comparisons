---
// OrnatePopupTrigger — convenience wrapper that renders a button-styled
// trigger for an OrnatePopup. Use when wrapping an existing element (a
// cartouche, a chart annotation, a comparison card) in a clickable trigger.
//
// For triggers whose visible text should look like prose (no button chrome),
// pass `as="prose"` for an underlined inline button.
//
// Implementation note: this element is <div role="button"> rather than
// <button> because the slotted children include block-level elements
// (ChapterPlate's annotation column, ComparisonPlate's full card body).
// The HTML spec forbids block content inside <button>; html-validate
// flagged 22 such violations across home + comparisons. The OrnatePopup
// controller adds a keydown handler so Enter and Space activate the
// trigger exactly as they would on a native button.
//
// Example:
//   <OrnatePopupTrigger popupId="how-the-hour-was-computed" as="cartouche">
//     <NumericCartouche … />
//   </OrnatePopupTrigger>

interface Props {
  popupId: string;
  as?: "cartouche" | "card" | "prose" | "bare";
  label?: string;
}

const { popupId, as = "bare", label } = Astro.props;
---

<div
  role="button"
  tabindex="0"
  class:list={["ornate-popup-trigger", `ornate-popup-trigger-${as}`]}
  data-popup-trigger={popupId}
  aria-haspopup="dialog"
  aria-expanded="false"
  aria-label={label}
>
  <slot />
</div>
