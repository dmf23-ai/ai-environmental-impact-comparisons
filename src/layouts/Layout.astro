---
import "../styles/global.css";
import OrnatePopup from "../components/OrnatePopup.astro";

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
  /**
   * Per-page social-share image. Path relative to the deployed site
   * (e.g. "/og-card.png"). Defaults to the site-wide card. Pages that
   * want their own preview (e.g. /comparisons with a specific framing)
   * can override.
   */
  ogImage?: string;
}
const { title, description, wide = false, ogImage = "/og-card.png" } = Astro.props;

// Astro.site is set in astro.config.mjs. When deploying to a custom domain,
// updating Astro.site there automatically threads through every absolute URL
// on the page — no Layout.astro change needed.
const siteUrl = Astro.site ?? new URL("https://ai-environmental-impact-comparisons.vercel.app");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const absoluteOgImage = new URL(ogImage, siteUrl).toString();
const siteName = "AI Environmental Impact Comparisons";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="canonical" href={canonicalUrl} />

    {/* Favicons */}
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <meta name="theme-color" content="#f4ede0" />

    {/* Open Graph — used by Slack, iMessage, Discord, LinkedIn, etc. */}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="AI Environmental Impact · Comparisons — side-by-side context for AI's energy and water use" />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={absoluteOgImage} />
    <meta name="twitter:image:alt" content="AI Environmental Impact · Comparisons — side-by-side context for AI's energy and water use" />

    {/* JSON-LD structured data — surfaces in Google sitelinks and rich results.
        WebPage carries the per-page details; isPartOf points at the parent
        WebSite so Google can group the pages under one entity. */}
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebPage",
        name: title,
        url: canonicalUrl,
        description: description ?? undefined,
        inLanguage: "en",
        isPartOf: {
          "@type": "WebSite",
          name: siteName,
          url: siteUrl.toString(),
        },
      })}
    />
  </head>
  <body>
    <header class="site-mast">
      <a href="/" class="wordmark"
        >AI Environmental Impact <span class="dot">·</span> Comparisons</a
      >
      <img
        class="masthead-strip"
        src="/ornaments/masthead-strip.png"
        alt=""
        aria-hidden="true"
        fetchpriority="high"
      />
    </header>
    <main class={wide ? "wide" : ""}>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-close">
        <p class="footer-italic">A shared starting point.</p>
        <p class="footer-italic">Numbers everyone can see.</p>
        <p class="footer-italic">Sources everyone can check.</p>
      </div>
      <div class="footer-cta">
        <a class="footer-cta-link" href="/comparisons"
          >View all comparisons →</a
        >
        <p class="footer-cta-sub">
          <a href="/methods">Read the methodology</a>
        </p>
      </div>
      <div class="footer-bottom">
        <img
          class="footer-roundel footer-roundel-left"
          src="/ornaments/footer-roundel-earth.png"
          alt=""
          aria-hidden="true"
        />
        <div class="footer-tagline-wrap">
          <hr class="footer-rule" aria-hidden="true" />
          <p class="footer-tagline">Sustainable futures require informed choices.</p>
        </div>
        <img
          class="footer-roundel footer-roundel-right"
          src="/ornaments/footer-roundel-landscape.png"
          alt=""
          aria-hidden="true"
        />
      </div>
      <p class="footer-credit">
        Open source ·
        <a
          href="https://github.com/dmf23-ai/ai-environmental-impact-comparisons"
          >code on GitHub</a
        > · sources verified weekly
      </p>
    </footer>
    <OrnatePopup />
  </body>
</html>
