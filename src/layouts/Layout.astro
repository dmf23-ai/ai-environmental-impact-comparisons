---
import "../styles/global.css";
import OrnatePopup from "../components/OrnatePopup.astro";

interface Props {
  title: string;
  description?: string;
  wide?: boolean;
}
const { title, description, wide = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
  </head>
  <body>
    <header class="site-mast">
      <a href="/" class="wordmark"
        >AI Environmental Impact <span class="dot">·</span> Comparisons</a
      >
      <img
        class="masthead-strip"
        src="/ornaments/masthead-strip.png"
        alt=""
        aria-hidden="true"
        fetchpriority="high"
      />
    </header>
    <main class={wide ? "wide" : ""}>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="footer-close">
        <p class="footer-italic">A shared starting point.</p>
        <p class="footer-italic">Numbers everyone can see.</p>
        <p class="footer-italic">Sources everyone can check.</p>
      </div>
      <div class="footer-cta">
        <a class="footer-cta-link" href="/comparisons"
          >View all comparisons →</a
        >
        <p class="footer-cta-sub">
          <a href="/methods">Read the methodology</a>
        </p>
      </div>
      <div class="footer-bottom">
        <img
          class="footer-roundel footer-roundel-left"
          src="/ornaments/footer-roundel-earth.png"
          alt=""
          aria-hidden="true"
        />
        <div class="footer-tagline-wrap">
          <hr class="footer-rule" aria-hidden="true" />
          <p class="footer-tagline">Sustainable futures require informed choices.</p>
        </div>
        <img
          class="footer-roundel footer-roundel-right"
          src="/ornaments/footer-roundel-landscape.png"
          alt=""
          aria-hidden="true"
        />
      </div>
      <p class="footer-credit">
        Open source ·
        <a
          href="https://github.com/dmf23-ai/ai-environmental-impact-comparisons"
          >code on GitHub</a
        > · sources verified weekly
      </p>
    </footer>
    <OrnatePopup />
  </body>
</html>
