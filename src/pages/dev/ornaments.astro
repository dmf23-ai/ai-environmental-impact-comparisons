---
import Layout from "../../layouts/Layout.astro";
import OrganicFrame from "../../components/OrganicFrame.astro";
import SectionDivider from "../../components/SectionDivider.astro";
---

<Layout title="Ornaments — dev" description="QA page for ornament primitives">
  <h1>Ornaments</h1>
  <p class="lede">
    Internal QA page for the Mucha's Notebook ornament library.
  </p>

  <h2>OrganicFrame with SubjectMarker</h2>
  <p>Three OrganicFrames, each with a different subject. The marker in the
  top-right corner identifies the subject at a glance.</p>

  <OrganicFrame subject="water">
    <p style="margin: 0;"><strong>Water.</strong> Teal droplet in the corner.
    Use on the water bracket chart, the water-vs-golf comparison, and anything
    measuring billion gallons.</p>
  </OrganicFrame>

  <OrganicFrame subject="electricity">
    <p style="margin: 0;"><strong>Electricity.</strong> Sage leaf in the corner.
    Use on annual TWh, the trajectory charts, household equivalents, the watt
    scale primer.</p>
  </OrganicFrame>

  <OrganicFrame subject="carbon">
    <p style="margin: 0;"><strong>Carbon.</strong> Rust diamond in the corner.
    Use on the hourly hero, training-vs-inference, and CO₂ comparison cards.</p>
  </OrganicFrame>

  <h2>SectionDividers in chapter order</h2>
  <p>How the dividers will read as the reader scrolls the home page.</p>

  <SectionDivider motif="carbon" />
  <p style="text-align: center; font-style: italic; color: var(--ink-faint); margin-top: 0;">
    The Hour
  </p>
  <SectionDivider motif="wheat" />
  <p style="text-align: center; font-style: italic; color: var(--ink-faint); margin-top: 0;">
    The Year
  </p>
  <SectionDivider motif="water" />
  <p style="text-align: center; font-style: italic; color: var(--ink-faint); margin-top: 0;">
    The Water
  </p>
  <SectionDivider motif="vine" />
  <p style="text-align: center; font-style: italic; color: var(--ink-faint); margin-top: 0;">
    The Trajectory
  </p>
  <SectionDivider motif="wheat" />
  <p style="text-align: center; font-style: italic; color: var(--ink-faint); margin-top: 0;">
    In Equivalents
  </p>
  <SectionDivider motif="carbon" />
  <p style="text-align: center; font-style: italic; color: var(--ink-faint); margin-top: 0;">
    Training vs. Inference
  </p>
</Layout>
