---
const title = "AI Environmental Impact Comparisons";
const description =
  "Numbers, ranges, and sources for what AI's environmental impact actually is — and what it isn't — measured against other ways we use water and electricity.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <h1>{title}</h1>
      <p class="lede">{description}</p>
      <p class="status">
        Under construction. The first comparisons — driving, gaming, golf courses — arrive in the next build.
      </p>
    </main>

    <style is:global>
      :root {
        --ink: #1a1a1a;
        --ink-soft: #4a4a4a;
        --paper: #fafaf7;
        --rule: #e6e3dc;
        --accent: #1f4f7a;
        --max-width: 38rem;
      }

      * { box-sizing: border-box; }

      html, body {
        margin: 0;
        padding: 0;
        background: var(--paper);
        color: var(--ink);
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Helvetica, Arial, sans-serif;
        font-size: 18px;
        line-height: 1.55;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      main {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 6rem 1.5rem 4rem;
      }

      h1 {
        font-size: 1.6rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        margin: 0 0 1.5rem;
        line-height: 1.25;
      }

      .lede {
        font-size: 1.15rem;
        color: var(--ink);
        margin: 0 0 2rem;
        max-width: 34rem;
      }

      .status {
        font-size: 0.95rem;
        color: var(--ink-soft);
        border-top: 1px solid var(--rule);
        padding-top: 1.25rem;
        margin: 0;
      }

      @media (min-width: 720px) {
        h1 { font-size: 2rem; }
        .lede { font-size: 1.25rem; }
      }
    </style>
  </body>
</html>
